ENV=dev

API_PORT=8000
FRONTEND_PORT=3000
API_INTERNAL_URL=http://api:8000

# Main Postgres (used by the API)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=openfincal
POSTGRES_PASSWORD=openfincal
POSTGRES_DB=openfincal

# Keycloak Postgres
KEYCLOAK_POSTGRES_USER=keycloak
KEYCLOAK_POSTGRES_PASSWORD=keycloak
KEYCLOAK_POSTGRES_DB=keycloak

# Keycloak
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
