ENV="dev"
VERSION="1.0.0"
TITLE="OPEN FINANCIAL CALENDAR API"

# ======================= <IDP PROVIDERS> ======================= #
GOOGLE_CLIENT_ID="google"
GOOGLE_CLIENT_SECRET="google"
# =============================================================== #



# =================== <BACKEND CONFIGURATION> =================== #
KEYCLOAK_EXT_URL="http://localhost:8080"
KEYCLOAK_ISSUER_URL="http://localhost:8080/realms/master"
KEYCLOAK_REDIRECT_URI="http://localhost/api/v1/system/callback"
POST_LOGOUT_REDIRECT_URI="http://localhost:3000"

BACKEND_EXT_URL="http://localhost"
FRONTEND_EXT_URL="http://localhost:3000"

MINIO_EXT_URL_API="http://localhost:6000"

CLIENT_SECRET_SHARED_DIRECTORY="./openfincal-storage/shared"

FRONTEND_COOKIE_SAMESITE="lax"
FRONTEND_COOKIE_SECURE="false"
# =============================================================== #



# ====================== <DATABASE CONFIG> ====================== #
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="password"
POSTGRES_HOST="postgres"
POSTGRES_DATABASE_DIRECTORY="./openfincal-storage/postgres"

KEYCLOAK_USER="keycloak"
KEYCLOAK_PASSWORD="keycloak_password"
KEYCLOAK_SCHEMA="keycloak"
KEYCLOAK_DB="openfincal"

OPENFINCAL_USER="openfincal"
OPENFINCAL_PASSWORD="openfincal_password"
OPENFINCAL_SCHEMA="public"
OPENFINCAL_DB="openfincal"
# =============================================================== #



# ====================== <KEYCLOAK CONFIG> ====================== #
KC_BOOTSTRAP_ADMIN_USERNAME="temp-admin"
KC_BOOTSTRAP_ADMIN_PASSWORD="admin"
KEYCLOAK_REALM="master"

KC_ADMIN_EMAIL="admin@freevo.es"
KC_ADMIN_USERNAME="admin"
KC_ADMIN_PASSWORD="admin"

# Database Connection for Keycloak
KC_DB="postgres"
KC_DB_USERNAME="keycloak"
KC_DB_PASSWORD="keycloak_password"
KC_DB_URL="jdbc:postgresql://postgres:5432/openfincal?currentSchema=keycloak"

# Keycloak Settings
KEYCLOAK_URL="http://keycloak:8080"
KEYCLOAK_BACKEND_CLIENT_ID="openfincal-api"
KEYCLOAK_FRONTEND_CLIENT_ID="openfincal-ui"
KC_HOSTNAME="localhost"
KC_HEALTH_ENABLED=true
KC_HTTP_ENABLED=true
KC_HOSTNAME_BACKCHANNEL_DYNAMIC=true
# =============================================================== #



# ==================== <REDIS CONFIGURATION> ==================== #
REDIS_STORAGE_DIRECTORY="./openfincal-storage/redis"
REDIS_HOST="redis"
# =============================================================== #



# ==================== <MINIO CONFIGURATION> ==================== #
MINIO_STORAGE_DIRECTORY="./openfincal-storage/minio"
MINIO_ROOT_USER="admin"
MINIO_ROOT_PASSWORD="password"

MINIO_ENDPOINT="http://minio:9000"
MINIO_BUCKET="system"
# =============================================================== #



# =================== <PGADMIN CONFIGURATION> =================== #
PGADMIN_DEFAULT_EMAIL="admin@openfincal.com"
PGADMIN_DEFAULT_PASSWORD="password"
# =============================================================== #



# =========================== <SEED> ============================ #
NUM_USERS=100
MAX_REVIEWS_PER_USER=20
# =============================================================== #



# =================== <HAPROXY CONFIGURATION> =================== #
HAPROXY_CONFIGURATION_FILE="./haproxy/haproxy.cfg"
# =============================================================== #


SMTP_HOST="mail.openfincal.com"
SMTP_PORT=587
SMTP_USER="noreply@openfincal.com"
SMTP_PASSWORD="password"
DISPLAY_NAME="Open Financial Calendar"

# ====================== <ELASTIC> ====================== #
ELASTICSEARCH_DIRECTORY="./openfincal-storage/elastic"
# ======================================================= #

# ======================= <KAFKA> ======================= #
KAFKA_DIRECTORY="./openfincal-storage/kafka"
# ======================================================= #