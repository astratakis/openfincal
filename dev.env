# Application
ENV=dev
VERSION=1.0.0
TITLE=openfincal

# uvicorn bind inside the api container
HOST=0.0.0.0
PORT=8000
CONTEXT_PATH=

# Compose-only port mappings (host side)
API_PORT=8000
FRONTEND_PORT=3000

# Used by frontend's next.config.js rewrite to reach the api inside docker
API_INTERNAL_URL=http://api:8000

# Frontend cookie / origin
FRONTEND_COOKIE_SECURE=false
FRONTEND_COOKIE_SAMESITE=lax
FRONTEND_EXT_URL=http://localhost:3000

# Main Postgres (used by the API)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=openfincal
POSTGRES_PASSWORD=openfincal
POSTGRES_DB=openfincal
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

# Keycloak Postgres
KEYCLOAK_POSTGRES_USER=keycloak
KEYCLOAK_POSTGRES_PASSWORD=keycloak
KEYCLOAK_POSTGRES_DB=keycloak

# Keycloak server
KEYCLOAK_PORT=8080

# Keycloak bootstrap admin — temporary user Keycloak auto-creates on first boot.
# kc-config logs in as this user, creates the persistent KC_ADMIN_* below,
# then deletes this user. Must NOT match KC_ADMIN_USERNAME.
KC_BOOTSTRAP_ADMIN_USERNAME=tempadmin
KC_BOOTSTRAP_ADMIN_PASSWORD=tempadmin

# Keycloak admin user that kc-config provisions in the realm (persistent)
KC_ADMIN_EMAIL=admin@openfincal.local
KC_ADMIN_USERNAME=admin
KC_ADMIN_PASSWORD=admin

# Keycloak (consumed by the api and kc-config)
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_EXT_URL=http://localhost:8080
KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/master
KEYCLOAK_REALM=master
POST_LOGOUT_REDIRECT_URI=http://localhost:3000/
KEYCLOAK_FRONTEND_CLIENT_ID=openfincal-frontend
KEYCLOAK_BACKEND_CLIENT_ID=openfincal-backend
KEYCLOAK_REDIRECT_URI=http://localhost:3000/api/v1/system/callback

# External (browser-facing) backend URL — used by kc-config when registering clients
BACKEND_EXT_URL=http://localhost:8000

# Shared dir into which kc-config writes the backend client secret;
# the api reads it from /usr/shared/client-secret.txt
CLIENT_SECRET_SHARED_DIRECTORY=./.shared

# Google IdP (leave empty to skip configuring Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP for Keycloak (leave empty to skip configuring email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
DISPLAY_NAME=openfincal

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# MinIO (no service in compose yet — values are placeholders)
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=openfincal
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio12345
MINIO_EXT_URL_API=http://localhost:9000
